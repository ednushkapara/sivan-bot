# ============================
# סיוון Bot — Environment Variables
# ============================
# Copy this file to .env and fill in the values.
# Never commit .env to git.

# --- Telegram ---
TELEGRAM_TOKEN=           # Get from @BotFather — create new bot named "סיוון"

# --- Anthropic ---
ANTHROPIC_API_KEY=        # Same key as Shimshon (or create a new one)

# --- Notion ---
NOTION_TOKEN=             # Same integration token as Shimshon
NOTION_PARENT_PAGE_ID=    # Page ID where Sivan's DBs will be created (from NOTION_SETUP.md step 1)
NOTION_LEADS_DB=          # Filled in after running: python notion_setup.py
NOTION_MUSIC_EVENTS_DB=   # Filled in after running: python notion_setup.py

# --- Shimshon Integration ---
SHIMSHON_TASKS_DB_ID=     # Copy from Shimshon's .env (same value)
